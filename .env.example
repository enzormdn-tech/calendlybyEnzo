TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Calendar OAuth2
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
