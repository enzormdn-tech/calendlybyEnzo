# Turso Database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Calendar OAuth2
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Run `npx tsx scripts/get-refresh-token.ts` to obtain this
GOOGLE_REFRESH_TOKEN=
# Optional: defaults to "primary" if not set
GOOGLE_CALENDAR_ID=

# Telegram Notifications
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Brevo (Email)
# Get API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Dashboard Auth
# Simple password to protect /dashboard routes
DASHBOARD_PASSWORD=

# Vercel Cron
# Secret to authenticate cron job requests
CRON_SECRET=
